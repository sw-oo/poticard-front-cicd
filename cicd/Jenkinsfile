// 3

pipeline {
  agent {
    kubernetes {
      label "node-kaniko-${UUID.randomUUID().toString()}"
      defaultContainer 'node'
      yaml """
apiVersion: v1
kind: Pod
metadata:
  namespace: csw
  annotations:
    sidecar.istio.io/inject: "false"
spec:
  restartPolicy: Never
  containers:
    - name: node
      image: node:22.17.1-bullseye
      command: ['cat']
      tty: true
    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command: ['/busybox/sh','-c','sleep infinity']
      tty: true
      volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
    - name: kubectl
      image: rancher/kubectl:v1.31.0
      command: ['cat']
      tty: true
      volumeMounts:
        - name: kubeconfig
          mountPath: /kube
          readOnly: true
  volumes:
    - name: docker-config
      secret:
        secretName: dockerhub-cred
        items:
          - key: .dockerconfigjson
            path: config.json
    - name: kubeconfig
      secret:
        secretName: jenkins-kubeconfig
        items:
          - key: config
            path: config
"""
    }
  }

  environment {
    IMAGE_NAME = 'seungwoo0128/frontend'
    IMAGE_TAG  = "3.${env.BUILD_NUMBER}"
    BACKEND_API_URL = 'http://192.100.5.114:8080'
    K8S_NAMESPACE = 'csw'
    UPDATE_STABLE = 'false'
  }

  stages {
    stage('Checkout') {
      steps {
        container('node') {
          checkout scm
        }
      }
    }

    stage('Build') {
      steps {
        container('node') {
          sh '''
            npm ci
            npm run build
          '''
        }
      }
    }

    stage('Kaniko Build & Push') {
      steps {
        container('kaniko') {
          sh """
            /kaniko/executor \\
              --context=${env.WORKSPACE} \\
              --dockerfile=${env.WORKSPACE}/cicd/Dockerfile \\
              --destination=${env.IMAGE_NAME}:${env.IMAGE_TAG} \\
              --destination=${env.IMAGE_NAME}:latest \\
              --single-snapshot \\
              --use-new-run \\
              --cache=true \\
              --snapshotMode=redo
          """
        }
      }
    }

    stage('Deploy to Kubernetes') {
      steps {
        container('kubectl') {
          sh """
            set -e
            export KUBECONFIG=/kube/config
            NS='${env.K8S_NAMESPACE}'
            CICD='${env.WORKSPACE}/cicd'

            kubectl apply -n "\${NS}" -f "\${CICD}/Frontend Service Stable.yaml"
            kubectl apply -n "\${NS}" -f "\${CICD}/Frontend Service Canary.yaml"
            kubectl apply -n "\${NS}" -f "\${CICD}/Frontend Ingress Stable.yaml"
            kubectl apply -n "\${NS}" -f "\${CICD}/Frontend Ingress Canary.yaml"

            sed "s|image:.*|        image: ${env.IMAGE_NAME}:${env.IMAGE_TAG}|" "\${CICD}/Frontend Deploy Canary.yaml" | kubectl apply -n "\${NS}" -f -

            if [ '${env.UPDATE_STABLE}' = 'true' ]; then
              sed "s|image:.*|        image: ${env.IMAGE_NAME}:${env.IMAGE_TAG}|" "\${CICD}/Frontend Deploy Stable.yaml" | kubectl apply -n "\${NS}" -f -
              kubectl rollout status deployment/poticard-frontend-stable -n "\${NS}" --timeout=180s
            fi

            kubectl rollout status deployment/poticard-frontend-canary -n "\${NS}" --timeout=180s
          """
        }
      }
    }

    stage('Result') {
      steps {
        echo "Pushed & deployed: ${env.IMAGE_NAME}:${env.IMAGE_TAG} (namespace: ${env.K8S_NAMESPACE})"
      }
    }
  }
}
